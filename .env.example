# Adaptive Ads Router Configuration

REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/adaptive_ads
AUDIT_DB_ENABLED=true
LAM_REGEN_URL=http://lam-regen:8018/regenerate

# Regime Thresholds
FIRST_100_THRESHOLD=100
NEURAL_THRESHOLD=1000

# Bandit Configuration
MIN_SAMPLES_PER_ARM=3
CONFIDENCE_THRESHOLD=0.95

# Diff Enforcement
MAX_DIFF_SCORE_FIRST_100=0.8
MAX_DIFF_SCORE_MIDDLE=0.4
MAX_DIFF_SCORE_NEURAL=0.1

LOG_LEVEL=INFO

# Optional admin token for cross-site management
ADMIN_API_KEY=

# Public base URL used in emailed report links
APP_BASE_URL=http://localhost:8024

# Weekly report scheduler (Friday 09:00 in REPORT_TIMEZONE by default)
REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_INTERVAL_SECONDS=300
REPORT_WORKER_ENABLED=true
REPORT_WORKER_POLL_SECONDS=5
REPORT_JOB_MAX_ATTEMPTS=3
REPORT_JOB_BACKOFF_SECONDS=30
REPORT_IDEMPOTENCY_TTL_SECONDS=1209600
REPORT_SEND_WEEKDAY=4
REPORT_SEND_HOUR=9
REPORT_TIMEZONE=America/Los_Angeles

# SMTP settings for scheduled report delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Provider delivery options: smtp | sendgrid | postmark
REPORT_DELIVERY_PROVIDER=smtp
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=

# Optional webhook secret for provider callbacks
REPORT_WEBHOOK_SECRET=

# Security controls
CSRF_TOKEN_TTL_SECONDS=3600
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MANAGEMENT_REQUESTS=120
RATE_LIMIT_REPORT_REQUESTS=240
